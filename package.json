{
  "name": "zengrab",
  "version": "0.0.1",
  "description": "Select context for coding agents directly from OpenTUI apps",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "example": "bun run build && bun run example/index.ts"
  },
  "keywords": [
    "opentui",
    "tui",
    "terminal",
    "grab",
    "agent",
    "context"
  ],
  "license": "MIT",
  "dependencies": {
    "@opentui/core": "^0.1.87",
    "clipboardy": "^4.0.0"
  },
  "devDependencies": {
    "tsup": "^8.2.4",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@opentui/core": ">=0.1.0"
  }
}
